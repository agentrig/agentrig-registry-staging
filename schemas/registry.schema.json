{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentrig.ai/schema/registry.json",
  "title": "AgentRig Registry Index",
  "type": "object",
  "required": [
    "$schema",
    "contract_version",
    "registry_alias",
    "source_repository",
    "generated_at",
    "signature",
    "items"
  ],
  "properties": {
    "$schema": {
      "const": "https://agentrig.ai/schema/registry.json"
    },
    "contract_version": {
      "type": "string",
      "const": "1"
    },
    "registry_alias": {
      "$ref": "https://agentrig.ai/schema/registry-contract.definitions.json#/$defs/registryAlias"
    },
    "source_repository": {
      "type": "string",
      "format": "uri"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "signature": {
      "type": "object",
      "required": [
        "algorithm",
        "key_id",
        "target",
        "signed_digest"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "sha256-json-envelope"
        },
        "key_id": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "const": "registry.json"
        },
        "signed_digest": {
          "$ref": "https://agentrig.ai/schema/registry-contract.definitions.json#/$defs/sha256Digest"
        }
      },
      "additionalProperties": false
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "artifact",
          "name",
          "description",
          "latest_version",
          "history",
          "active_version",
          "trust_tier",
          "installability"
        ],
        "properties": {
          "kind": {
            "$ref": "https://agentrig.ai/schema/registry-contract.definitions.json#/$defs/artifactKind"
          },
          "artifact": {
            "$ref": "https://agentrig.ai/schema/registry-contract.definitions.json#/$defs/artifactId"
          },
          "plugin": {
            "$ref": "https://agentrig.ai/schema/registry-contract.definitions.json#/$defs/pluginId"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "latest_version": {
            "$ref": "https://agentrig.ai/schema/registry-contract.definitions.json#/$defs/semver"
          },
          "history": {
            "$ref": "https://agentrig.ai/schema/registry-contract.definitions.json#/$defs/canonicalHistoryPath"
          },
          "active_version": {
            "$ref": "https://agentrig.ai/schema/registry-contract.definitions.json#/$defs/activeVersionRecord"
          },
          "trust_tier": {
            "$ref": "https://agentrig.ai/schema/registry-contract.definitions.json#/$defs/trustTier"
          },
          "installability": {
            "$ref": "https://agentrig.ai/schema/registry-contract.definitions.json#/$defs/installabilityState"
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "advisories": {
            "type": "array",
            "items": {
              "$ref": "https://agentrig.ai/schema/registry-contract.definitions.json#/$defs/advisoryId"
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "trust_tier": {
                  "const": "official"
                }
              }
            },
            "then": {
              "properties": {
                "installability": {
                  "const": "installable"
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "trust_tier": {
                  "const": "reviewed"
                }
              }
            },
            "then": {
              "properties": {
                "installability": {
                  "const": "installable"
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "trust_tier": {
                  "const": "listed"
                }
              }
            },
            "then": {
              "properties": {
                "installability": {
                  "const": "discovery_only"
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "trust_tier": {
                  "const": "blocked"
                }
              }
            },
            "then": {
              "properties": {
                "installability": {
                  "const": "blocked"
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "trust_tier": {
                  "const": "yanked"
                }
              }
            },
            "then": {
              "properties": {
                "installability": {
                  "const": "yanked"
                }
              }
            }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
